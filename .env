# ============================================================
#  PowerFaultAI - Environment Configuration
#  NEVER commit .env to version control.
# ============================================================

# Flask
FLASK_ENV=development
FLASK_DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string-in-production
PORT=5000

# IBM Cloud Credentials
# Get your API key: https://cloud.ibm.com/iam/apikeys
IBM_API_KEY=

# IBM Watson Machine Learning (optional)
IBM_WML_URL=https://us-south.ml.cloud.ibm.com
IBM_WML_INSTANCE_ID=your-wml-instance-id-here

# IBM Watson Assistant (optional)
IBM_WA_API_KEY=your-watson-assistant-api-key-here
IBM_WA_SERVICE_URL=https://api.us-south.assistant.watson.cloud.ibm.com
IBM_WA_ASSISTANT_ID=your-assistant-id-here

# IBM Event Notifications (optional)
IBM_EN_GUID=your-event-notifications-guid-here
IBM_EN_URL=https://us-south.event-notifications.cloud.ibm.com

# Thresholds
CONFIDENCE_THRESHOLD=0.55
ALERT_SEVERITY_THRESHOLD=High

# App
APP_TITLE=PowerFaultAI
APP_ORG=IBM Power Systems Division
LOG_LEVEL=INFO
